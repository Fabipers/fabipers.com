---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { slugify } from '../utils/slugify';

// Generate paths for all blog posts and pages
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  const pageEntries = await getCollection('pages');
  
  const blogPaths = blogEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry, type: 'post' }
  }));
  
  const pagePaths = pageEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry, type: 'page' }
  }));
  
  return [...blogPaths, ...pagePaths];
}

const { entry, type } = Astro.props;
const { Content } = await render(entry);

// Format date helper
const formatDate = (dateStr: string | Date) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const title = `${entry.data.title} | Fabipers`;
const description = entry.data.description || `Leer ${entry.data.title} en fabipers.com.`;
---

<Layout title={title} description={description}>
  {type === 'post' ? (
    /* Blog Post 2-Column Layout */
    <div class="post-layout section">
      <div class="container blog-container-2col">
        <!-- Main Content (70%) -->
        <article class="post-main-content">
          <header class="post-header-brutalist">
            <div class="post-meta">
              <time datetime={entry.data.pubDate.toString()}>{formatDate(entry.data.pubDate)}</time>
              {entry.data.categories && entry.data.categories.length > 0 && (
                <span class="post-category highlight-box">{entry.data.categories[0]}</span>
              )}
            </div>
            <h1 class="post-title-brutalist">{entry.data.title}</h1>
            
            {entry.data.tags && entry.data.tags.length > 0 && (
              <div class="post-tags">
                {entry.data.tags.map((tag: string) => (
                  <a href={`/blog/tag/${slugify(tag)}/`} class="tag-badge-link highlight-box" id={`post-tag-${slugify(tag)}`}>#{tag}</a>
                ))}
              </div>
            )}
          </header>

          <div class="post-content-brutalist">
            <Content />
          </div>

          <footer class="post-footer">
            <div class="post-cta card text-center">
              <h3>¿Quieres potenciar tus campañas de marketing?</h3>
              <p>Escríbeme por WhatsApp y analicemos cómo mejorar el retorno de inversión (ROI) de tus anuncios digitales.</p>
              <a href="https://api.whatsapp.com/send?phone=+573182873558&text=Quiero%20una%20asesor%C3%ADa" class="btn btn-whatsapp" id="post-cta-btn" target="_blank" rel="noopener noreferrer">
                Hablemos hoy mismo
              </a>
            </div>
          </footer>
        </article>

        <!-- Sticky Sidebar (30%) -->
        <aside class="post-sidebar">
          <div class="card sidebar-widget sticky-sidebar">
            <div class="avatar-container">
              <div class="avatar-halo"></div>
              <div class="avatar-placeholder">FP</div>
            </div>
            
            <h3 class="sidebar-author-name">Fabián Pérez</h3>
            <span class="sidebar-author-title highlight-box">Trafficker Digital</span>
            
            <p class="sidebar-author-bio">
              Especialista en tráfico de pago y analítica web. Ayudo a negocios a optimizar al máximo el ROI de sus campañas digitales en Google Ads y Facebook Ads.
            </p>
            
            <div class="sidebar-actions">
              <a href="https://api.whatsapp.com/send?phone=+573182873558&text=Quiero%20una%20asesor%C3%ADa" class="btn btn-primary" id="sidebar-cta-whatsapp" target="_blank" rel="noopener noreferrer">
                💬 WhatsApp Directo
              </a>
            </div>
          </div>
        </aside>
      </div>
      
      <!-- Mobile Floating CTA -->
      <div class="mobile-floating-cta">
        <div class="mobile-cta-content">
          <span class="mobile-cta-text">🚀 ¿Quieres mejores resultados?</span>
          <a href="https://api.whatsapp.com/send?phone=+573182873558&text=Quiero%20una%20asesor%C3%ADa" class="btn btn-primary" id="mobile-cta-btn" target="_blank" rel="noopener noreferrer">
            Agendar Asesoría
          </a>
        </div>
      </div>
    </div>
  ) : (
    /* Static Page Layout (Single Column) */
    <div class="page-layout section">
      <div class="container page-container">
        <header class="page-header text-center">
          <h1 class="page-title-brutalist">{entry.data.title}</h1>
        </header>
        <div class="page-content-brutalist">
          <Content />
        </div>
      </div>
    </div>
  )}
</Layout>

<style is:global>
  /* Blog Container 2 Columns */
  .blog-container-2col {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }
  
  @media (min-width: 992px) {
    .blog-container-2col {
      grid-template-columns: 1.4fr 0.6fr;
    }
  }
  
  .post-main-content {
    min-width: 0; /* Prevents grid flex overflow */
  }
  
  .post-header-brutalist {
    margin-bottom: 3rem;
  }
  
  .post-title-brutalist {
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-top: 1rem;
  }
  
  .page-title-brutalist {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 2rem;
  }
  
  /* Markdown content styling */
  .post-content-brutalist, .page-content-brutalist {
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--text-primary);
  }
  
  .post-content-brutalist p, .page-content-brutalist p {
    margin-bottom: 1.8rem;
    font-weight: 500;
  }
  
  /* Indicators on H2 headings */
  .post-content-brutalist h2, .page-content-brutalist h2 {
    font-size: 1.7rem;
    font-weight: 800;
    margin-top: 3.5rem;
    margin-bottom: 1.2rem;
    position: relative;
    padding-left: 1.5rem;
    border-left: 4px solid var(--accent-primary);
  }
  
  .post-content-brutalist h3, .page-content-brutalist h3 {
    font-size: 1.35rem;
    font-weight: 800;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .post-content-brutalist ul, .post-content-brutalist ol,
  .page-content-brutalist ul, .page-content-brutalist ol {
    margin-bottom: 1.8rem;
    padding-left: 2rem;
    font-weight: 500;
  }
  
  .post-content-brutalist li, .page-content-brutalist li {
    margin-bottom: 0.6rem;
  }
  
  .post-content-brutalist a, .page-content-brutalist a {
    color: var(--text-primary);
    text-decoration: underline;
    background-color: var(--accent-alpha);
    padding: 0 0.2rem;
    font-weight: 600;
  }
  
  .post-content-brutalist a:hover, .page-content-brutalist a:hover {
    background-color: var(--accent-primary);
  }
  
  .post-content-brutalist blockquote, .page-content-brutalist blockquote {
    border: 3px solid var(--border-color);
    padding: 2rem;
    margin: 2.5rem 0;
    background-color: var(--bg-secondary);
    box-shadow: 4px 4px 0px var(--border-color);
    font-style: italic;
    font-weight: 600;
  }
  
  .post-content-brutalist img, .page-content-brutalist img {
    border: 3px solid var(--border-color);
    box-shadow: 6px 6px 0px var(--border-color);
    margin: 2.5rem 0;
    border-radius: 0px;
  }
  
  /* Sidebar styles */
  .post-sidebar {
    display: block;
  }
  
  .sticky-sidebar {
    position: sticky;
    top: 6rem;
    z-index: 10;
  }
  
  .sidebar-widget {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 2rem;
  }
  
  .avatar-container {
    position: relative;
    width: 110px;
    height: 110px;
    margin-bottom: 1.5rem;
  }
  
  .avatar-halo {
    position: absolute;
    top: -4px;
    left: -4px;
    width: 118px;
    height: 118px;
    border: 3px solid var(--border-color);
    background-color: var(--accent-primary);
    transform: rotate(4deg);
    z-index: 1;
  }
  
  .avatar-placeholder {
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: var(--text-primary);
    color: var(--bg-primary);
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 3px solid var(--border-color);
    z-index: 2;
  }
  
  .sidebar-author-name {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  
  .sidebar-author-title {
    font-size: 0.8rem;
    padding: 0.2rem 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    transform: rotate(-1deg);
  }
  
  .sidebar-author-bio {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-weight: 500;
    line-height: 1.6;
  }
  
  .sidebar-actions {
    width: 100%;
  }
  
  .sidebar-actions .btn {
    width: 100%;
    border-width: 3px;
  }
  
  /* Mobile Floating CTA */
  .mobile-floating-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: var(--bg-primary);
    border-top: 3px solid var(--border-color);
    padding: 1rem var(--container-padding);
    z-index: 99;
    display: none;
    box-shadow: 0 -4px 15px rgba(0, 0, 0, 0.05);
  }
  
  .mobile-cta-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 800px;
    margin: 0 auto;
  }
  
  .mobile-cta-text {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.95rem;
  }
  
  .mobile-floating-cta .btn {
    padding: 0.6rem 1.2rem;
    font-size: 0.85rem;
    border-width: 2px;
    box-shadow: 2px 2px 0px var(--border-color);
  }
  
  @media (max-width: 991px) {
    .mobile-floating-cta {
      display: block;
    }
    
    /* Add extra padding at the bottom of the page to avoid content occlusion by the floating CTA */
    .post-layout {
      padding-bottom: 8rem;
    }
  }
</style>
