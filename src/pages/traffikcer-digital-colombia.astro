---
import Layout from '../layouts/Layout.astro';

// SEO Title & Description
const title = "Trafficker Digital en Colombia | Especialista en Google & Meta Ads";
const description = "Multiplica tus clientes y ventas en Bogotá y toda Colombia con campañas de publicidad digital de alto impacto. Especialista en optimizar el ROI.";
---

<Layout title={title} description={description}>
  <!-- Schema: ProfessionalService (Colombia) JSON-LD -->
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Fabián Pérez - Trafficker Digital",
      "image": "https://fabipers.com/og-image.jpg",
      "url": "https://fabipers.com/traffikcer-digital-colombia",
      "telephone": "+573182873558",
      "priceRange": "$$",
      "description": "Especialista en tráfico de pago (Google Ads, Meta Ads) y analítica web avanzada para escalar negocios en Colombia. Optimización de ROI con presupuestos locales.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bogotá",
        "addressRegion": "Cundinamarca",
        "addressCountry": "CO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 4.6097,
        "longitude": -74.0817
      },
      "areaServed": {
        "@type": "Country",
        "name": "Colombia"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios de Pauta Digital",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Trafficker Google Ads" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Trafficker Meta Ads" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Analítica Web & Tracking" } }
        ]
      },
      "sameAs": [
        "https://linkedin.com/in/fabian-perez-trafficker",
        "https://instagram.com/fabipers"
      ]
    }
  </script>

  <!-- Hero Section -->
  <section class="section hero-section" id="hero">
    <div class="container hero-grid">
      <div class="hero-content">
        <div class="badge-wrapper">
          <span class="hero-badge rotate-left">⚡ Especialista en Ads & Tráfico en Colombia</span>
        </div>
        <h1 class="hero-title">
          Multiplica tus clientes en Colombia con publicidad de <span class="highlight-text">ALTO IMPACTO</span>
        </h1>
        <p class="hero-subtitle">
          ¿Buscas un Trafficker Digital en Bogotá que entienda el mercado colombiano y optimice cada peso de tu presupuesto? Aumento las ventas de tu negocio con estrategias de conversión avanzadas.
        </p>
        <div class="hero-actions">
          <a href="https://api.whatsapp.com/send?phone=+573182873558&text=Quiero%20una%20asesor%C3%ADa%20en%20Colombia" class="btn btn-whatsapp" id="hero-cta-whatsapp" target="_blank" rel="noopener noreferrer">
            <span class="whatsapp-icon">💬</span> Hablemos por WhatsApp
          </a>
          <a href="#servicios" class="btn btn-secondary" id="hero-cta-services">
            Ver Servicios
          </a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="visual-cube card rotate-right">
          <span class="cube-tag highlight-box">COLOMBIA</span>
          <div class="stat-box">
            <span class="stat-num">+150%</span>
            <span class="stat-lbl">Retorno de Inversión</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem vs Solution (Brutalist blocks) -->
  <section class="section compare-section" id="compare">
    <div class="container">
      <div class="grid grid-2">
        <div class="card problem-card">
          <span class="card-tag rotate-left">El Problema</span>
          <h2>¿Cansado de gastar en clics que no te traen clientes?</h2>
          <p>Muchos negocios en Colombia delegan sus campañas en agencias tradicionales que solo reportan métricas de vanidad como 'impresiones' o 'likes'. Al final de mes, el presupuesto en pesos se agota y las ventas siguen igual.</p>
        </div>
        <div class="card solution-card">
          <span class="card-tag rotate-right highlight-box">La Solución</span>
          <h2>Optimización estricta basada en conversiones reales</h2>
          <p>Estructuro tus embudos de ventas en pesos colombianos (COP), configurando la atribución de conversiones de forma exacta. Enfocamos la inversión en lo que realmente genera contactos de WhatsApp y ventas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section services-section" id="servicios">
    <div class="container">
      <div class="section-header text-center">
        <span class="step-subtitle">Servicios para Colombia</span>
        <h2>Estrategias hechas para facturar más</h2>
      </div>

      <div class="grid grid-3">
        <div class="card service-card">
          <div class="service-icon">📈</div>
          <h3>Paid Ads & Traffic</h3>
          <p>Administración experta de campañas en Google Ads, Meta Ads y TikTok Ads para todo el territorio colombiano.</p>
        </div>

        <div class="card service-card">
          <div class="service-icon">🔍</div>
          <h3>SEO & Orgánico</h3>
          <p>Posicionamiento orgánico en Google para búsquedas de alta intención en Bogotá, Medellín, Cali y Barranquilla.</p>
        </div>

        <div class="card service-card">
          <div class="service-icon">⚙️</div>
          <h3>Embudos & Analítica</h3>
          <p>Integración de Google Analytics 4, Tag Manager y WhatsApp Business para tener trazabilidad del 100% de tus prospectos.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section steps-section" id="steps">
    <div class="container">
      <div class="section-header text-center">
        <span class="step-subtitle">Metodología de Trabajo</span>
        <h2>Cuatro sencillos pasos para el crecimiento</h2>
      </div>
      
      <div class="grid grid-2 step-grid">
        <div class="card step-card">
          <div class="step-number rotate-left">01</div>
          <h3>Análisis Estratégico</h3>
          <p>Revisamos tu producto o servicio, tus competidores en el mercado nacional y tu historial publicitario en pesos para trazar el camino más rentable.</p>
        </div>
        
        <div class="card step-card">
          <div class="step-number rotate-right">02</div>
          <h3>Planificación y Funnel</h3>
          <p>Diseñamos el embudo (usualmente con WhatsApp como canal de cierre preferido en Colombia) y establecemos la segmentación ideal de audiencias.</p>
        </div>
        
        <div class="card step-card">
          <div class="step-number rotate-left">03</div>
          <h3>Implementación y Lanzamiento</h3>
          <p>Estructuramos las campañas desde cero en las herramientas oficiales de Google y Facebook, redactando anuncios persuasivos dirigidos a tu cliente ideal.</p>
        </div>
        
        <div class="card step-card">
          <div class="step-number rotate-right">04</div>
          <h3>Optimización Semanal</h3>
          <p>Realizamos ajustes diarios de presupuestos, audiencias y creativos para asegurar que mantengas un costo por lead bajo y rentable.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Local CTA Section -->
  <section class="section local-cta-section" id="local-cta">
    <div class="container">
      <div class="cta-banner-brutalist">
        <h2>¿Quieres auditar tu estrategia actual en Colombia?</h2>
        <p>Hablemos por WhatsApp y analicemos de forma gratuita tu embudo de ventas, el coste por cliente potencial actual y tus oportunidades de optimización.</p>
        <a href="https://api.whatsapp.com/send?phone=+573182873558&text=Quiero%20una%20asesor%C3%ADa%20en%20Colombia" class="btn btn-primary" id="colombia-footer-cta-btn" target="_blank" rel="noopener noreferrer">
          ⚡ Agendar Auditoría Gratuita
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Styles */
  .hero-section {
    padding: 8rem 0 5rem 0;
  }
  
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  @media (min-width: 992px) {
    .hero-grid {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }
  
  .badge-wrapper {
    margin-bottom: 1.5rem;
  }
  
  .hero-badge {
    background-color: var(--text-primary);
    color: var(--accent-primary);
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 1rem;
    border: 2px solid var(--border-color);
    display: inline-block;
  }
  
  .hero-title {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 1.8rem;
    font-weight: 900;
  }
  
  .highlight-text {
    background-color: var(--accent-primary);
    color: #000000;
    padding: 0 0.5rem;
    border: 3px solid var(--border-color);
    box-shadow: 3px 3px 0px var(--border-color);
    display: inline-block;
    transform: rotate(-0.5deg);
    margin-top: 0.2rem;
  }
  
  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    margin-bottom: 2.8rem;
    max-width: 650px;
    font-weight: 500;
  }
  
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .hero-actions .btn {
    border-width: 3px;
  }
  
  /* Cube visual */
  .hero-visual {
    display: flex;
    justify-content: center;
  }
  
  .visual-cube {
    width: 250px;
    height: 250px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-primary);
    position: relative;
    padding: 2rem;
  }
  
  .cube-tag {
    position: absolute;
    top: -15px;
    left: 20px;
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    transform: rotate(-3deg);
  }
  
  .stat-box {
    text-align: center;
  }
  
  .stat-num {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 3.8rem;
    line-height: 1;
    color: var(--text-primary);
    display: block;
    margin-bottom: 0.5rem;
  }
  
  .stat-lbl {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.9rem;
    text-transform: uppercase;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
  }
  
  /* Compare Section */
  .compare-section {
    background-color: var(--bg-secondary);
    border-top: 3px solid var(--border-color);
    border-bottom: 3px solid var(--border-color);
  }
  
  .problem-card, .solution-card {
    position: relative;
    padding: 3rem 2rem;
    height: 100%;
  }
  
  .problem-card .card-tag, .solution-card .card-tag {
    position: absolute;
    top: -18px;
    left: 20px;
    font-size: 0.8rem;
    padding: 0.25rem 0.65rem;
    font-family: var(--font-heading);
    font-weight: 800;
    text-transform: uppercase;
  }
  
  .problem-card .card-tag {
    background-color: var(--text-primary);
    color: #ffffff;
    border: 2px solid var(--border-color);
  }
  
  .problem-card h2, .solution-card h2 {
    font-size: 1.5rem;
    font-weight: 900;
    margin-bottom: 1.2rem;
  }
  
  .problem-card p, .solution-card p {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.95rem;
    line-height: 1.6;
  }
  
  /* Services Section */
  .service-card {
    padding: 2.5rem 2rem;
    height: 100%;
  }
  
  .service-icon {
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }
  
  .service-card h3 {
    font-size: 1.3rem;
    font-weight: 900;
    margin-bottom: 0.8rem;
  }
  
  .service-card p {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  
  /* Steps Section */
  .steps-section {
    background-color: var(--bg-secondary);
    border-top: 3px solid var(--border-color);
    border-bottom: 3px solid var(--border-color);
  }
  
  .step-grid {
    margin-top: 4rem;
  }
  
  .step-card {
    padding: 2.5rem;
    position: relative;
    height: 100%;
  }
  
  .step-number {
    position: absolute;
    top: -15px;
    left: 20px;
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 1.4rem;
    background-color: var(--accent-primary);
    color: #000000;
    border: 2px solid var(--border-color);
    box-shadow: 2px 2px 0px var(--border-color);
    padding: 0.1rem 0.5rem;
  }
  
  .step-card h3 {
    font-size: 1.25rem;
    font-weight: 900;
    margin-bottom: 0.8rem;
    margin-top: 0.5rem;
  }
  
  .step-card p {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  
  /* CTA banner */
  .cta-banner-brutalist {
    background-color: var(--text-primary);
    color: var(--bg-primary);
    border: 3px solid var(--border-color);
    padding: 4rem 3rem;
    text-align: center;
    box-shadow: 6px 6px 0px var(--border-color);
  }
  
  .cta-banner-brutalist h2 {
    color: #ffffff;
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }
  
  .cta-banner-brutalist p {
    color: var(--bg-tertiary);
    max-width: 600px;
    margin: 0 auto 2.5rem auto;
    font-size: 1.1rem;
    font-weight: 500;
  }
  
  .cta-banner-brutalist .btn-primary {
    background-color: var(--accent-primary);
    color: #000000;
    box-shadow: 4px 4px 0px #ffffff;
    border-color: #ffffff;
  }
  
  .cta-banner-brutalist .btn-primary:hover {
    background-color: var(--accent-hover);
    box-shadow: 6px 6px 0px #ffffff;
  }
</style>
