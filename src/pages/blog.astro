---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Fetch and sort blog posts
const posts = await getCollection('blog');
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

import { slugify } from '../utils/slugify';

// Extract all unique tags dynamically
const allTagsMap = new Map<string, string>(); // slug -> display name
posts.forEach(post => {
  if (post.data.tags) {
    post.data.tags.forEach(tag => {
      allTagsMap.set(slugify(tag), tag);
    });
  }
});
const uniqueTags = Array.from(allTagsMap.entries());

const title = "Blog | Trafficker Digital & Marketing Online";
const description = "Artículos prácticos sobre tráfico de pago, Google Ads, Facebook Ads, analítica web y estrategias de conversión para empresas.";

// Helper to format date
const formatDate = (dateStr: string | Date) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<Layout title={title} description={description}>
  <section class="section blog-header-section">
    <div class="container text-center">
      <span class="blog-subtitle highlight-box">Estrategias y Métricas</span>
      <h1 class="blog-title">El Blog del <span>Trafficker Digital</span></h1>
      <p class="blog-desc">Aprende sobre optimización de campañas, analítica web avanzada, herramientas clave y secretos para maximizar tus conversiones.</p>
    </div>
  </section>

  <!-- Tag Filter Bar -->
  <section class="tag-filter-section">
    <div class="container">
      <div class="tag-bar-card card">
        <span class="tag-bar-title">Filtrar por Etiqueta:</span>
        <div class="tag-list-flex">
          <a href="/blog/" class="tag-filter-item active" id="tag-filter-all">Todos</a>
          {uniqueTags.map(([slug, name]) => (
            <a href={`/blog/tag/${slug}/`} class="tag-filter-item" id={`tag-filter-${slug}`}>
              {name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="blog-grid-section">
    <div class="container">
      {sortedPosts.length === 0 ? (
        <div class="no-posts card text-center">
          <p>No se encontraron artículos publicados.</p>
        </div>
      ) : (
        <div class="grid grid-3">
          {sortedPosts.map((post) => (
            <article class="card blog-card">
              <div class="blog-meta">
                <time datetime={post.data.pubDate.toString()}>{formatDate(post.data.pubDate)}</time>
                {post.data.categories && post.data.categories.length > 0 && (
                  <a href={`/blog/tag/${slugify(post.data.categories[0])}/`} class="blog-category" id={`post-${post.id}-cat-${slugify(post.data.categories[0])}`}>{post.data.categories[0]}</a>
                )}
              </div>
              
              <h2 class="blog-card-title">
                <a href={`/${post.id}/`} id={`blog-post-link-${post.id}`}>{post.data.title}</a>
              </h2>
              
              <p class="blog-card-excerpt">
                {post.data.description.replace(/^Migrado de WordPress: /, "")}
              </p>
              
              <div class="blog-card-footer">
                <div class="card-tags-list">
                  {post.data.tags && post.data.tags.slice(0, 2).map((tag) => (
                    <a href={`/blog/tag/${slugify(tag)}/`} class="blog-tag-link" id={`post-${post.id}-tag-${slugify(tag)}`}>
                      #{tag}
                    </a>
                  ))}
                </div>
                <a href={`/${post.id}/`} class="blog-readmore" aria-label={`Leer más sobre ${post.data.title}`} id={`read-more-${post.id}`}>
                  Leer &rarr;
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .blog-header-section {
    padding-top: 6rem;
    padding-bottom: 2rem;
  }
  
  .blog-subtitle {
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  
  .blog-title {
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    letter-spacing: -0.03em;
    margin-bottom: 1.2rem;
    font-weight: 900;
  }
  
  .blog-title span {
    background-color: var(--accent-primary);
    color: #000000;
    padding: 0 0.5rem;
    border: 3px solid var(--border-color);
    box-shadow: 3px 3px 0px var(--border-color);
    display: inline-block;
    transform: rotate(-1deg);
  }
  
  .blog-desc {
    color: var(--text-secondary);
    max-width: 650px;
    margin: 0 auto;
    font-size: 1.15rem;
    font-weight: 500;
  }

  /* Tag Filter Bar Styles */
  .tag-filter-section {
    padding-bottom: 3rem;
  }

  .tag-bar-card {
    padding: 1.5rem 2rem;
    border-radius: 0px;
  }

  .tag-bar-title {
    font-family: var(--font-heading);
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.9rem;
    display: block;
    margin-bottom: 0.8rem;
  }

  .tag-list-flex {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .tag-filter-item {
    background-color: var(--bg-secondary);
    color: var(--text-primary);
    border: 2px solid var(--border-color);
    padding: 0.4rem 1rem;
    font-weight: 700;
    font-size: 0.85rem;
    transition: all var(--transition-fast);
  }

  .tag-filter-item:hover, .tag-filter-item.active {
    background-color: var(--accent-primary);
    transform: translate(-1px, -1px);
    box-shadow: 2px 2px 0px var(--border-color);
  }
  
  /* Blog Grid */
  .blog-grid-section {
    padding-bottom: 6rem;
  }
  
  .blog-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 2rem;
  }
  
  .blog-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    width: 100%;
    font-weight: 600;
  }
  
  .blog-category {
    background: var(--text-primary);
    color: var(--accent-primary);
    padding: 0.25rem 0.6rem;
    border: 2px solid var(--border-color);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .blog-category:hover {
    background: var(--text-primary);
    color: var(--accent-primary);
  }

  .blog-tag-link:hover {
    color: var(--text-primary);
    background-color: var(--accent-alpha);
  }
  
  .blog-card-title {
    font-size: 1.4rem;
    margin-bottom: 1.2rem;
    line-height: 1.25;
    font-weight: 900;
  }
  
  .blog-card-title a {
    color: #09090b !important; /* Always black */
    transition: background-color var(--transition-fast);
    display: inline;
  }
  
  .blog-card-title a:hover {
    background-color: var(--accent-primary);
    color: #09090b !important;
  }
  
  .blog-card-excerpt {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 1.8rem;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    line-clamp: 3;
    overflow: clip;
    font-weight: 500;
  }
  
  .blog-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 2px solid var(--border-color);
    padding-top: 1.2rem;
    margin-top: auto;
    font-size: 0.85rem;
  }

  .card-tags-list {
    display: flex;
    gap: 0.5rem;
  }
  
  .blog-tag-link {
    color: var(--text-muted);
    font-weight: 700;
    text-decoration: none;
  }

  .blog-tag-link:hover {
    color: var(--text-primary);
    background-color: rgba(163, 230, 53, 0.25);
  }
  
  .blog-readmore {
    font-family: var(--font-heading);
    font-weight: 800;
    color: var(--text-primary);
    text-transform: uppercase;
    font-size: 0.85rem;
  }
  
  .blog-readmore:hover {
    color: var(--accent-hover);
    text-decoration: underline;
  }
</style>
