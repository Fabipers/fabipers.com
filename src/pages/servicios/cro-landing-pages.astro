---
import Layout from '../../layouts/Layout.astro';

const title = "Páginas de Aterrizaje CRO & Optimización de Conversión | Funnel Builder";
const description = "Diseño y optimización de landings de conversión ultra rápidas con React y Astro, maximizando las tasas de conversión de tus campañas.";
---

<Layout title={title} description={description}>
  <!-- Schema: FAQPage JSON-LD -->
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Por qué es importante la velocidad de carga de una landing page?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Cada segundo de demora en móviles reduce la tasa de conversión en un 20%. Si estás pagando por cada clic en anuncios, un sitio lento significa quemar dinero antes de que el usuario vea tu propuesta de valor."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué es CRO?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "CRO (Conversion Rate Optimization) es el conjunto de técnicas científicas y de diseño utilizadas para incrementar el porcentaje de visitantes de tu web que realizan una acción deseada (comprar, rellenar un formulario)."
          }
        },
        {
          "@type": "Question",
          "name": "¿Tengo que contratar hosting y dominio aparte para mi landing page?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yo me encargo de sugerirte las mejores alternativas (como Cloudflare, Vercel o servidores VPS con Coolify) y ayudarte con la configuración de DNS para que tu sitio cargue a la velocidad de la luz."
          }
        }
      ]
    }
  </script>
  <!-- Hero Section -->
  <section class="section service-hero-detail" id="hero">
    <div class="container srv-detail-grid">
      <div class="srv-hero-content">
        <div class="badge-wrapper">
          <span class="hero-badge rotate-left">⚡ Landing Pages & CRO</span>
        </div>
        <h1 class="hero-title">
          Convierte más clics en clientes con <span class="highlight-text">Landings CRO</span>
        </h1>
        <p class="hero-subtitle">
          El tráfico es inútil si llega a una página lenta y confusa. Construyo páginas de aterrizaje ligeras, persuasivas y optimizadas al milisegundo bajo metodologías CRO para multiplicar tus tasas de conversión.
        </p>
        <div class="hero-actions">
          <a href="/servicios#cotizador-sec" class="btn btn-primary" id="cro-cta-quote">
            ⚡ Cotizar Diseño Landings
          </a>
          <a href="https://api.whatsapp.com/send?phone=+573182873558&text=Hola%20Fabi%C3%A1n,%20quiero%20cotizar%20servicios%20de%20CRO%20y%20Landing%20Pages" class="btn btn-whatsapp" id="cro-cta-whatsapp" target="_blank" rel="noopener noreferrer">
            💬 WhatsApp Directo
          </a>
        </div>
      </div>

      <div class="srv-hero-visual">
        <div class="visual-stat-card card rotate-right">
          <span class="stat-badge highlight-box">CRO LANDINGS</span>
          <div class="stat-group">
            <span class="stat-number">&lt; 1s</span>
            <span class="stat-label">Tiempo de Carga en Dispositivos Móviles</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Metrics / Key value -->
  <section class="section metrics-section" id="metrics">
    <div class="container">
      <div class="grid grid-3">
        <div class="card metric-card text-center">
          <h3>Velocidad Extrema</h3>
          <p>Desarrollo estático moderno con Astro y React. Tiempos de carga mínimos significan menor rebote en campañas.</p>
        </div>
        <div class="card metric-card text-center">
          <h3>Estructura Persuasiva</h3>
          <p>Copywriting enfocado en la conversión, resolviendo objeciones y facilitando la toma de decisión.</p>
        </div>
        <div class="card metric-card text-center">
          <h3>A/B Testing Local</h3>
          <p>Diseño experimental de cabeceras, formularios y botones de acción para refinar qué funciona mejor.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section process-section" id="proceso">
    <div class="container">
      <div class="section-header text-center">
        <span class="step-subtitle">Mi Metodología</span>
        <h2>¿Cómo Trabajaremos en CRO & Landings?</h2>
      </div>

      <div class="grid grid-4 step-grid">
        <div class="card step-card">
          <div class="step-number rotate-left">01</div>
          <h3>Copywriting</h3>
          <p>Estructuramos los textos de venta y el flujo narrativo enfocado a resolver los dolores de tu cliente.</p>
        </div>

        <div class="card step-card">
          <div class="step-number rotate-right">02</div>
          <h3>Diseño Brutalista</h3>
          <p>Diseñamos una UI limpia, llamativa y de alto contraste que prioriza los botones de acción.</p>
        </div>

        <div class="card step-card">
          <div class="step-number rotate-left">03</div>
          <h3>Desarrollo</h3>
          <p>Programamos el sitio con código ultra optimizado libre de código innecesario o plugins pesados.</p>
        </div>

        <div class="card step-card">
          <div class="step-number rotate-right">04</div>
          <h3>Optimización</h3>
          <p>Analizamos mapas de calor e interacciones de usuarios para seguir afinando las tasas de conversión.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section faq-section" id="faq">
    <div class="container">
      <div class="section-header text-center">
        <span class="step-subtitle">Dudas Comunes</span>
        <h2>Preguntas Frecuentes sobre CRO</h2>
      </div>

      <div class="faq-wrap card">
        <div class="faq-item">
          <h4>¿Por qué es importante la velocidad de carga de una landing page?</h4>
          <p>Cada segundo de demora en móviles reduce la tasa de conversión en un 20%. Si estás pagando por cada clic en anuncios, un sitio lento significa quemar dinero antes de que el usuario vea tu propuesta de valor.</p>
        </div>

        <div class="faq-item">
          <h4>¿Qué es CRO?</h4>
          <p>CRO (Conversion Rate Optimization) es el conjunto de técnicas científicas y de diseño utilizadas para incrementar el porcentaje de visitantes de tu web que realizan una acción deseada (comprar, rellenar un formulario).</p>
        </div>

        <div class="faq-item">
          <h4>¿Tengo que contratar hosting y dominio aparte?</h4>
          <p>Yo me encargo de sugerirte las mejores alternativas (como Cloudflare, Vercel o servidores VPS con Coolify) y ayudarte con la configuración de DNS para que tu sitio cargue a la velocidad de la luz.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="section detail-cta-section">
    <div class="container">
      <div class="cta-banner-brutalist">
        <h2>¿Quieres multiplicar las ventas de tus anuncios de pauta?</h2>
        <p>Hablemos por WhatsApp y diseñemos una página de aterrizaje de alto impacto y conversión extrema.</p>
        <a href="/servicios#cotizador-sec" class="btn btn-primary" id="cro-bottom-cta">
          ⚡ Cotizar mi landing page
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .service-hero-detail {
    padding: 8rem 0 5rem 0;
  }

  .srv-detail-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 992px) {
    .srv-detail-grid {
      grid-template-columns: 1.25fr 0.75fr;
    }
  }

  .badge-wrapper {
    margin-bottom: 1.5rem;
  }

  .hero-badge {
    background-color: var(--text-primary);
    color: var(--accent-primary);
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 1rem;
    border: 2px solid var(--border-color);
    display: inline-block;
  }

  .hero-title {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 1.8rem;
    font-weight: 900;
  }

  .highlight-text {
    background-color: var(--accent-primary);
    color: #000000;
    padding: 0 0.5rem;
    border: 3px solid var(--border-color);
    box-shadow: 3px 3px 0px var(--border-color);
    display: inline-block;
    transform: rotate(-0.5deg);
    margin-top: 0.2rem;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    margin-bottom: 2.8rem;
    max-width: 650px;
    font-weight: 500;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero-actions .btn {
    border-width: 3px;
  }

  .srv-hero-visual {
    display: flex;
    justify-content: center;
  }

  .visual-stat-card {
    width: 260px;
    height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-primary);
    position: relative;
    padding: 2rem;
  }

  .stat-badge {
    position: absolute;
    top: -15px;
    left: 20px;
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    transform: rotate(-3deg);
  }

  .stat-group {
    text-align: center;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 3.5rem;
    color: var(--text-primary);
    display: block;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.85rem;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .metrics-section {
    background-color: var(--bg-secondary);
    border-top: 3px solid var(--border-color);
    border-bottom: 3px solid var(--border-color);
  }

  .metric-card {
    padding: 2.5rem 2rem;
  }

  .metric-card h3 {
    font-size: 1.3rem;
    font-weight: 900;
    margin-bottom: 0.8rem;
  }

  .metric-card p {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .process-section {
    padding-bottom: 5rem;
  }

  .step-grid {
    margin-top: 4rem;
  }

  .step-card {
    padding: 2.5rem 2rem;
    position: relative;
    height: 100%;
  }

  .step-number {
    position: absolute;
    top: -15px;
    left: 20px;
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 1.4rem;
    background-color: var(--accent-primary);
    color: #000000;
    border: 2px solid var(--border-color);
    box-shadow: 2px 2px 0px var(--border-color);
    padding: 0.1rem 0.5rem;
  }

  .step-card h3 {
    font-size: 1.25rem;
    font-weight: 900;
    margin-bottom: 0.8rem;
    margin-top: 0.5rem;
  }

  .step-card p {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* FAQ Styles */
  .faq-section {
    background-color: var(--bg-secondary);
    border-top: 3px solid var(--border-color);
    border-bottom: 3px solid var(--border-color);
  }

  .faq-wrap {
    max-width: 800px;
    margin: 3rem auto 0 auto;
    padding: 3rem;
  }

  .faq-item {
    margin-bottom: 2.5rem;
  }

  .faq-item:last-child {
    margin-bottom: 0;
  }

  .faq-item h4 {
    font-size: 1.2rem;
    font-weight: 900;
    margin-bottom: 0.8rem;
    position: relative;
    padding-left: 1.5rem;
  }

  .faq-item h4::before {
    content: "Q.";
    position: absolute;
    left: 0;
    color: var(--accent-primary);
    font-weight: 900;
  }

  .faq-item p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    font-weight: 500;
    padding-left: 1.5rem;
  }

  /* CTA banner */
  .cta-banner-brutalist {
    background-color: var(--text-primary);
    color: var(--bg-primary);
    border: 3px solid var(--border-color);
    padding: 4rem 3rem;
    text-align: center;
    box-shadow: 6px 6px 0px var(--border-color);
  }

  .cta-banner-brutalist h2 {
    color: #ffffff;
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }

  .cta-banner-brutalist p {
    color: var(--bg-tertiary);
    max-width: 600px;
    margin: 0 auto 2.5rem auto;
    font-size: 1.1rem;
    font-weight: 500;
  }

  .cta-banner-brutalist .btn-primary {
    background-color: var(--accent-primary);
    color: #000000;
    box-shadow: 4px 4px 0px #ffffff;
    border-color: #ffffff;
  }

  .cta-banner-brutalist .btn-primary:hover {
    background-color: var(--accent-hover);
    box-shadow: 6px 6px 0px #ffffff;
  }
</style>
