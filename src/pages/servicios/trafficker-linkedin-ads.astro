---
import Layout from '../../layouts/Layout.astro';

const title = "Trafficker LinkedIn Ads | Publicidad B2B de Alto Valor";
const description = "Captura tomadores de decisiones corporativas, dueños de negocios y leads B2B de ticket alto con campañas altamente segmentadas en LinkedIn Ads.";
---

<Layout title={title} description={description}>
  <!-- Schema: FAQPage JSON-LD -->
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Por qué LinkedIn Ads es más costoso que Facebook Ads?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El coste por clic en LinkedIn es más alto debido a la calidad de la base de datos y la capacidad única de segmentar por cargos y datos profesionales reales. Es ideal para negocios B2B donde un solo cliente cerrado compensa con creces el costo del lead."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué es el LinkedIn Insight Tag?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Es el píxel de seguimiento de LinkedIn. Te permite entender qué perfiles profesionales visitan tu web, crear públicos de retargeting en base a su industria y medir las conversiones de tus anuncios."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué formatos de anuncios son recomendables en LinkedIn?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Los formularios de generación de prospectos (Lead Gen Forms) combinados con imágenes estáticas o videos cortos ofrecen excelentes tasas de conversión debido a la fricción mínima al rellenar datos."
          }
        }
      ]
    }
  </script>
  <!-- Hero Section -->
  <section class="section service-hero-detail" id="hero">
    <div class="container srv-detail-grid">
      <div class="srv-hero-content">
        <div class="badge-wrapper">
          <span class="hero-badge rotate-left">⚡ Especialista en LinkedIn Ads</span>
        </div>
        <h1 class="hero-title">
          Conecta con tomadores de decisiones en <span class="highlight-text">LinkedIn Ads</span>
        </h1>
        <p class="hero-subtitle">
          Especialista en estructurar campañas de captación B2B de alto valor. Te ayudo a impactar a profesionales, gerentes y CEOs específicos según su cargo, sector, tamaño de empresa y decisiones ejecutivas.
        </p>
        <div class="hero-actions">
          <a href="/servicios#cotizador-sec" class="btn btn-primary" id="linkedin-cta-quote">
            ⚡ Cotizar Campaña
          </a>
          <a href="https://api.whatsapp.com/send?phone=+573182873558&text=Hola%20Fabi%C3%A1n,%20quiero%20cotizar%20campa%C3%B1as%20de%20LinkedIn%20Ads" class="btn btn-whatsapp" id="linkedin-cta-whatsapp" target="_blank" rel="noopener noreferrer">
            💬 WhatsApp Directo
          </a>
        </div>
      </div>

      <div class="srv-hero-visual">
        <div class="visual-stat-card card rotate-right">
          <span class="stat-badge highlight-box">LINKEDIN ADS</span>
          <div class="stat-group">
            <span class="stat-number">B2B</span>
            <span class="stat-label">Segmentación Profesional Exacta</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Metrics / Key value -->
  <section class="section metrics-section" id="metrics">
    <div class="container">
      <div class="grid grid-3">
        <div class="card metric-card text-center">
          <h3>Lead Gen Forms</h3>
          <p>Formularios integrados nativos que se rellenan automáticamente con los datos del perfil del usuario.</p>
        </div>
        <div class="card metric-card text-center">
          <h3>Filtros por Cargo</h3>
          <p>Segmenta campañas por cargo exacto, antigüedad, sector, y tamaño de facturación o empleados de la compañía.</p>
        </div>
        <div class="card metric-card text-center">
          <h3>Mensajes InMail</h3>
          <p>Anuncios directos al buzón de entrada de profesionales de alto nivel con tasas de apertura increíbles.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section process-section" id="proceso">
    <div class="container">
      <div class="section-header text-center">
        <span class="step-subtitle">Mi Metodología</span>
        <h2>¿Cómo Trabajaremos en LinkedIn Ads?</h2>
      </div>

      <div class="grid grid-4 step-grid">
        <div class="card step-card">
          <div class="step-number rotate-left">01</div>
          <h3>Perfilado</h3>
          <p>Definimos con precisión quirúrgica el Buyer Persona corporativo (ICPs, industrias, cargos).</p>
        </div>

        <div class="card step-card">
          <div class="step-number rotate-right">02</div>
          <h3>Configuración</h3>
          <p>Alineamos el tag de seguimiento de LinkedIn (Insight Tag) para medir conversiones y configurar públicos.</p>
        </div>

        <div class="card step-card">
          <div class="step-number rotate-left">03</div>
          <h3>Anuncios</h3>
          <p>Redactamos mensajes con enfoque profesional que apelan a problemáticas y soluciones del negocio.</p>
        </div>

        <div class="card step-card">
          <div class="step-number rotate-right">04</div>
          <h3>Optimización</h3>
          <p>Monitoreamos costes por lead y optimizamos los presupuestos para obtener prospectos de alto ticket.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section faq-section" id="faq">
    <div class="container">
      <div class="section-header text-center">
        <span class="step-subtitle">Dudas Comunes</span>
        <h2>Preguntas Frecuentes sobre LinkedIn Ads</h2>
      </div>

      <div class="faq-wrap card">
        <div class="faq-item">
          <h4>¿Por qué LinkedIn Ads es más costoso que Facebook Ads?</h4>
          <p>El coste por clic en LinkedIn es más alto debido a la calidad de la base de datos y la capacidad única de segmentar por cargos y datos profesionales reales. Es ideal para negocios B2B donde un solo cliente cerrado compensa con creces el costo del lead.</p>
        </div>

        <div class="faq-item">
          <h4>¿Qué es el LinkedIn Insight Tag?</h4>
          <p>Es el píxel de seguimiento de LinkedIn. Te permite entender qué perfiles profesionales visitan tu web, crear públicos de retargeting en base a su industria y medir las conversiones de tus anuncios.</p>
        </div>

        <div class="faq-item">
          <h4>¿Qué formatos de anuncios son recomendables?</h4>
          <p>Los formularios de generación de prospectos (Lead Gen Forms) combinados con imágenes estáticas o videos cortos ofrecen excelentes tasas de conversión debido a la fricción mínima al rellenar datos.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="section detail-cta-section">
    <div class="container">
      <div class="cta-banner-brutalist">
        <h2>¿Quieres captar clientes corporativos de alto valor?</h2>
        <p>Hablemos por WhatsApp y diseñemos tu segmentación profesional de LinkedIn Ads.</p>
        <a href="/servicios#cotizador-sec" class="btn btn-primary" id="linkedin-bottom-cta">
          ⚡ Cotizar mis campañas
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .service-hero-detail {
    padding: 8rem 0 5rem 0;
  }

  .srv-detail-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 992px) {
    .srv-detail-grid {
      grid-template-columns: 1.25fr 0.75fr;
    }
  }

  .badge-wrapper {
    margin-bottom: 1.5rem;
  }

  .hero-badge {
    background-color: var(--text-primary);
    color: var(--accent-primary);
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 1rem;
    border: 2px solid var(--border-color);
    display: inline-block;
  }

  .hero-title {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 1.8rem;
    font-weight: 900;
  }

  .highlight-text {
    background-color: var(--accent-primary);
    color: #000000;
    padding: 0 0.5rem;
    border: 3px solid var(--border-color);
    box-shadow: 3px 3px 0px var(--border-color);
    display: inline-block;
    transform: rotate(-0.5deg);
    margin-top: 0.2rem;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--text-secondary);
    margin-bottom: 2.8rem;
    max-width: 650px;
    font-weight: 500;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero-actions .btn {
    border-width: 3px;
  }

  .srv-hero-visual {
    display: flex;
    justify-content: center;
  }

  .visual-stat-card {
    width: 260px;
    height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-primary);
    position: relative;
    padding: 2rem;
  }

  .stat-badge {
    position: absolute;
    top: -15px;
    left: 20px;
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    transform: rotate(-3deg);
  }

  .stat-group {
    text-align: center;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 3.5rem;
    color: var(--text-primary);
    display: block;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 0.85rem;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .metrics-section {
    background-color: var(--bg-secondary);
    border-top: 3px solid var(--border-color);
    border-bottom: 3px solid var(--border-color);
  }

  .metric-card {
    padding: 2.5rem 2rem;
  }

  .metric-card h3 {
    font-size: 1.3rem;
    font-weight: 900;
    margin-bottom: 0.8rem;
  }

  .metric-card p {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .process-section {
    padding-bottom: 5rem;
  }

  .step-grid {
    margin-top: 4rem;
  }

  .step-card {
    padding: 2.5rem 2rem;
    position: relative;
    height: 100%;
  }

  .step-number {
    position: absolute;
    top: -15px;
    left: 20px;
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 1.4rem;
    background-color: var(--accent-primary);
    color: #000000;
    border: 2px solid var(--border-color);
    box-shadow: 2px 2px 0px var(--border-color);
    padding: 0.1rem 0.5rem;
  }

  .step-card h3 {
    font-size: 1.25rem;
    font-weight: 900;
    margin-bottom: 0.8rem;
    margin-top: 0.5rem;
  }

  .step-card p {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* FAQ Styles */
  .faq-section {
    background-color: var(--bg-secondary);
    border-top: 3px solid var(--border-color);
    border-bottom: 3px solid var(--border-color);
  }

  .faq-wrap {
    max-width: 800px;
    margin: 3rem auto 0 auto;
    padding: 3rem;
  }

  .faq-item {
    margin-bottom: 2.5rem;
  }

  .faq-item:last-child {
    margin-bottom: 0;
  }

  .faq-item h4 {
    font-size: 1.2rem;
    font-weight: 900;
    margin-bottom: 0.8rem;
    position: relative;
    padding-left: 1.5rem;
  }

  .faq-item h4::before {
    content: "Q.";
    position: absolute;
    left: 0;
    color: var(--accent-primary);
    font-weight: 900;
  }

  .faq-item p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    font-weight: 500;
    padding-left: 1.5rem;
  }

  /* CTA banner */
  .cta-banner-brutalist {
    background-color: var(--text-primary);
    color: var(--bg-primary);
    border: 3px solid var(--border-color);
    padding: 4rem 3rem;
    text-align: center;
    box-shadow: 6px 6px 0px var(--border-color);
  }

  .cta-banner-brutalist h2 {
    color: #ffffff;
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 1rem;
  }

  .cta-banner-brutalist p {
    color: var(--bg-tertiary);
    max-width: 600px;
    margin: 0 auto 2.5rem auto;
    font-size: 1.1rem;
    font-weight: 500;
  }

  .cta-banner-brutalist .btn-primary {
    background-color: var(--accent-primary);
    color: #000000;
    box-shadow: 4px 4px 0px #ffffff;
    border-color: #ffffff;
  }

  .cta-banner-brutalist .btn-primary:hover {
    background-color: var(--accent-hover);
    box-shadow: 6px 6px 0px #ffffff;
  }
</style>
