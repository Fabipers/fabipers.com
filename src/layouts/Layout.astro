---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Fabipers | Trafficker Digital & Full Stack Marketer", 
	description = "Te ayudo a hacer crecer tu negocio mediante campañas publicitarias altamente efectivas, analítica avanzada y optimización de conversiones." 
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalURL = new URL(Astro.url.pathname, 'https://fabipers.com');
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Google Fonts Preconnect & Stylesheet -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@600;700;800;900&display=swap" rel="stylesheet">
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL.href} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL.href} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<slot name="head" />
	</head>
	<body>
		<!-- Header / Nav -->
		<header>
			<div class="container header-container">
				<a href="/" class="logo" id="header-logo-link">
					fabipers<span>.com</span>
				</a>
				
				<nav aria-label="Navegación principal">
					<ul class="nav-links">
						<li>
							<a href="/" class={currentPath === "/" || currentPath === "" ? "active" : ""} id="nav-home">
								Inicio
							</a>
						</li>
						<li>
							<a href="/blog" class={currentPath.startsWith("/blog") ? "active" : ""} id="nav-blog">
								Blog
							</a>
						</li>
						<li>
							<a href="/sobre-mi" class={currentPath === "/sobre-mi" ? "active" : ""} id="nav-about">
								Sobre mí
							</a>
						</li>
						<li class="dropdown">
							<button class="dropdown-trigger" aria-expanded="false" id="nav-locations-btn">
								Ubicaciones <span class="arrow">▼</span>
							</button>
							<ul class="dropdown-menu">
								<li>
									<a href="/traffikcer-digital-colombia" class={currentPath === "/traffikcer-digital-colombia" ? "active" : ""} id="nav-loc-colombia">
										🇨🇴 Colombia
									</a>
								</li>
								<li>
									<a href="/traffikcer-digital-miami" class={currentPath === "/traffikcer-digital-miami" ? "active" : ""} id="nav-loc-miami">
										🇺🇸 Miami
									</a>
								</li>
							</ul>
						</li>
						<li>
							<a href="https://api.whatsapp.com/send?phone=+573182873558&text=Quiero%20una%20asesor%C3%ADa" class="btn btn-primary" id="nav-cta" target="_blank" rel="noopener noreferrer">
								Hablemos
							</a>
						</li>
					</ul>
				</nav>
			</div>
		</header>

		<!-- Main Content Slot -->
		<main>
			<slot />
		</main>

		<!-- Footer -->
		<footer>
			<div class="container">
				<div class="footer-grid">
					<div class="footer-info">
						<a href="/" class="logo" id="footer-logo-link">
							fabipers<span>.com</span>
						</a>
						<p>Especialista en tráfico de pago y optimización de conversión. Conectando tu negocio con clientes de alto valor.</p>
					</div>
					
					<div class="footer-links">
						<h4>Navegación</h4>
						<ul>
							<li><a href="/" id="footer-nav-home">Inicio</a></li>
							<li><a href="/blog" id="footer-nav-blog">Blog</a></li>
							<li><a href="/sobre-mi" id="footer-nav-about">Sobre mí</a></li>
							<li><a href="/traffikcer-digital-colombia" id="footer-nav-loc-colombia">🇨🇴 Colombia</a></li>
							<li><a href="/traffikcer-digital-miami" id="footer-nav-loc-miami">🇺🇸 Miami</a></li>
						</ul>
					</div>
					
					<div class="footer-links">
						<h4>Contacto</h4>
						<ul>
							<li><a href="https://api.whatsapp.com/send?phone=+573182873558&text=Quiero%20una%20asesor%C3%ADa" target="_blank" rel="noopener noreferrer" id="footer-contact-whatsapp">WhatsApp</a></li>
							<li><a href="mailto:fabipers@gmail.com" id="footer-contact-email">Email</a></li>
						</ul>
					</div>
				</div>
				
				<div class="footer-bottom">
					<p>&copy; {new Date().getFullYear()} fabipers.com. Todos los derechos reservados.</p>
					<div class="social-links">
						<a href="https://twitter.com/fabipers" target="_blank" rel="noopener noreferrer" aria-label="Twitter/X" id="social-twitter">𝕏</a>
						<a href="https://instagram.com/fabipers" target="_blank" rel="noopener noreferrer" aria-label="Instagram" id="social-instagram">IG</a>
						<a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" id="social-linkedin">LN</a>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>

<style is:global>
  /* Dropdown Styles */
  .dropdown {
    position: relative;
    display: inline-block;
  }

  .dropdown-trigger {
    background: none;
    border: none;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text-primary);
    padding: 0.5rem 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .dropdown-trigger:hover {
    color: var(--accent-primary);
  }

  .dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background-color: var(--bg-primary);
    border: 3px solid var(--border-color);
    box-shadow: 4px 4px 0px var(--border-color);
    padding: 0.5rem 0;
    list-style: none;
    z-index: 100;
    min-width: 160px;
    margin: 0;
  }

  .dropdown-menu li {
    margin: 0;
  }

  .dropdown-menu a {
    display: block;
    padding: 0.6rem 1.2rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: background-color var(--transition-fast);
  }

  .dropdown-menu a:hover {
    background-color: var(--accent-primary);
    color: #000000;
  }

  /* Show dropdown menu on hover */
  .dropdown:hover .dropdown-menu,
  .dropdown:focus-within .dropdown-menu {
    display: block;
  }

  .dropdown-trigger .arrow {
    font-size: 0.7rem;
    transition: transform 0.2s ease;
  }

  .dropdown:hover .dropdown-trigger .arrow {
    transform: rotate(180deg);
  }
</style>
