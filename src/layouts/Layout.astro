---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Fabipers | Trafficker Digital & Full Stack Marketer", 
	description = "Te ayudo a hacer crecer tu negocio mediante campañas publicitarias altamente efectivas, analítica avanzada y optimización de conversiones." 
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalURL = new URL(Astro.url.pathname, 'https://fabipers.com');
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Google Fonts Preconnect & Stylesheet -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@600;700;800;900&display=swap" rel="stylesheet">
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL.href} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL.href} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<slot name="head" />
	</head>
	<body>
		<!-- Header / Nav -->
		<header>
			<div class="container header-container">
				<a href="/" class="logo" id="header-logo-link">
					fabipers<span>.com</span>
				</a>
				
				<nav aria-label="Navegación principal">
					<ul class="nav-links">
						<li>
							<a href="/" class={currentPath === "/" || currentPath === "" ? "active" : ""} id="nav-home">
								Inicio
							</a>
						</li>
						<li class="dropdown">
							<a href="/servicios" class={currentPath.startsWith("/servicios") ? "active dropdown-trigger" : "dropdown-trigger"} id="nav-services-btn">
								Servicios <span class="arrow">▼</span>
							</a>
							<ul class="dropdown-menu">
								<li>
									<a href="/servicios/trafficker-google-ads" id="nav-srv-google">
										🔍 Google Ads
									</a>
								</li>
								<li>
									<a href="/servicios/trafficker-facebook-ads" id="nav-srv-facebook">
										📱 Meta Ads
									</a>
								</li>
								<li>
									<a href="/servicios/trafficker-linkedin-ads" id="nav-srv-linkedin">
										💼 LinkedIn Ads
									</a>
								</li>
								<li>
									<a href="/servicios/analitica-web-tracking" id="nav-srv-tracking">
										📊 Analítica & Tracking
									</a>
								</li>
								<li>
									<a href="/servicios/cro-landing-pages" id="nav-srv-cro">
										💻 CRO & Landings
									</a>
								</li>
							</ul>
						</li>
						<li>
							<a href="/blog" class={currentPath.startsWith("/blog") ? "active" : ""} id="nav-blog">
								Blog
							</a>
						</li>
						<li>
							<a href="/sobre-mi" class={currentPath === "/sobre-mi" ? "active" : ""} id="nav-about">
								Sobre mí
							</a>
						</li>
						<li class="dropdown">
							<button class="dropdown-trigger" aria-expanded="false" id="nav-locations-btn">
								Ubicaciones <span class="arrow">▼</span>
							</button>
							<ul class="dropdown-menu">
								<li>
									<a href="/traffikcer-digital-colombia" class={currentPath === "/traffikcer-digital-colombia" ? "active" : ""} id="nav-loc-colombia">
										🇨🇴 Colombia
									</a>
								</li>
								<li>
									<a href="/traffikcer-digital-miami" class={currentPath === "/traffikcer-digital-miami" ? "active" : ""} id="nav-loc-miami">
										🇺🇸 Miami
									</a>
								</li>
							</ul>
						</li>
						<li>
							<a href="https://api.whatsapp.com/send?phone=+573182873558&text=Quiero%20una%20asesor%C3%ADa" class="btn btn-primary" id="nav-cta" target="_blank" rel="noopener noreferrer">
								Hablemos
							</a>
						</li>
					</ul>
				</nav>
				
				<button class="hamburger-btn" aria-label="Abrir menú" aria-expanded="false" id="menu-toggle-btn">
					☰
				</button>
			</div>
		</header>

		<!-- Main Content Slot -->
		<main>
			<slot />
		</main>

		<!-- Footer -->
		<footer>
			<div class="container">
				<div class="footer-grid">
					<div class="footer-info">
						<a href="/" class="logo" id="footer-logo-link">
							fabipers<span>.com</span>
						</a>
						<p>Especialista en tráfico de pago y optimización de conversión. Conectando tu negocio con clientes de alto valor.</p>
					</div>
					
					<div class="footer-links">
						<h4>Navegación</h4>
						<ul>
							<li><a href="/" id="footer-nav-home">Inicio</a></li>
							<li><a href="/blog" id="footer-nav-blog">Blog</a></li>
							<li><a href="/sobre-mi" id="footer-nav-about">Sobre mí</a></li>
							<li><a href="/traffikcer-digital-colombia" id="footer-nav-loc-colombia">🇨🇴 Colombia</a></li>
							<li><a href="/traffikcer-digital-miami" id="footer-nav-loc-miami">🇺🇸 Miami</a></li>
						</ul>
					</div>
					
					<div class="footer-links">
						<h4>Servicios</h4>
						<ul>
							<li><a href="/servicios/trafficker-google-ads" id="footer-nav-srv-google">Google Ads</a></li>
							<li><a href="/servicios/trafficker-facebook-ads" id="footer-nav-srv-facebook">Meta Ads</a></li>
							<li><a href="/servicios/trafficker-linkedin-ads" id="footer-nav-srv-linkedin">LinkedIn Ads</a></li>
							<li><a href="/servicios/analitica-web-tracking" id="footer-nav-srv-tracking">Analítica & Tracking</a></li>
							<li><a href="/servicios/cro-landing-pages" id="footer-nav-srv-cro">CRO & Landings</a></li>
						</ul>
					</div>
					
					<div class="footer-links">
						<h4>Contacto</h4>
						<ul>
							<li><a href="https://api.whatsapp.com/send?phone=+573182873558&text=Quiero%20una%20asesor%C3%ADa" target="_blank" rel="noopener noreferrer" id="footer-contact-whatsapp">WhatsApp</a></li>
							<li><a href="mailto:fabipers@gmail.com" id="footer-contact-email">Email</a></li>
						</ul>
					</div>
				</div>
				
				<div class="footer-bottom">
					<p>&copy; {new Date().getFullYear()} fabipers.com. Todos los derechos reservados.</p>
					<div class="social-links">
						<a href="https://twitter.com/fabipers" target="_blank" rel="noopener noreferrer" aria-label="Twitter/X" id="social-twitter">𝕏</a>
						<a href="https://instagram.com/fabipers" target="_blank" rel="noopener noreferrer" aria-label="Instagram" id="social-instagram">IG</a>
						<a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" id="social-linkedin">LN</a>
					</div>
				</div>
			</div>
		</footer>

		<!-- Mobile Drawer Structure -->
		<div class="mobile-drawer" id="mobile-menu-drawer">
			<div class="mobile-drawer-header">
				<a href="/" class="logo">
					fabipers<span>.com</span>
				</a>
				<button class="close-btn" id="menu-close-btn" aria-label="Cerrar menú">&times;</button>
			</div>
			<nav class="mobile-drawer-nav">
				<ul>
					<li>
						<a href="/">Inicio</a>
					</li>
					<li>
						<div class="mobile-nav-group-title">Servicios</div>
						<ul class="mobile-submenu">
							<li><a href="/servicios/trafficker-google-ads">🔍 Google Ads</a></li>
							<li><a href="/servicios/trafficker-facebook-ads">📱 Meta Ads</a></li>
							<li><a href="/servicios/trafficker-linkedin-ads">💼 LinkedIn Ads</a></li>
							<li><a href="/servicios/analitica-web-tracking">📊 Analítica & Tracking</a></li>
							<li><a href="/servicios/cro-landing-pages">💻 CRO & Landings</a></li>
							<li><a href="/servicios" class="view-all-services">Ver todos los servicios &rarr;</a></li>
						</ul>
					</li>
					<li>
						<a href="/blog">Blog</a>
					</li>
					<li>
						<a href="/sobre-mi">Sobre mí</a>
					</li>
					<li>
						<div class="mobile-nav-group-title">Ubicaciones</div>
						<ul class="mobile-submenu">
							<li><a href="/traffikcer-digital-colombia">🇨🇴 Colombia</a></li>
							<li><a href="/traffikcer-digital-miami">🇺🇸 Miami</a></li>
						</ul>
					</li>
					<li class="mobile-cta-li">
						<a href="https://api.whatsapp.com/send?phone=+573182873558&text=Quiero%20una%20asesor%C3%ADa" class="btn btn-primary" target="_blank" rel="noopener noreferrer" id="mobile-nav-cta">
							HABLEMOS
						</a>
					</li>
				</ul>
			</nav>
		</div>
		<div class="mobile-overlay" id="mobile-menu-overlay"></div>

		<script>
			const toggleBtn = document.getElementById('menu-toggle-btn');
			const closeBtn = document.getElementById('menu-close-btn');
			const drawer = document.getElementById('mobile-menu-drawer');
			const overlay = document.getElementById('mobile-menu-overlay');

			if (toggleBtn && closeBtn && drawer && overlay) {
				const openMenu = () => {
					drawer.classList.add('open');
					overlay.classList.add('open');
					document.body.style.overflow = 'hidden';
				};

				const closeMenu = () => {
					drawer.classList.remove('open');
					overlay.classList.remove('open');
					document.body.style.overflow = '';
				};

				toggleBtn.addEventListener('click', openMenu);
				closeBtn.addEventListener('click', closeMenu);
				overlay.addEventListener('click', closeMenu);

				const links = drawer.querySelectorAll('a');
				links.forEach(link => {
					link.addEventListener('click', closeMenu);
				});
			}
		</script>
	</body>
</html>

<style is:global>
  /* Dropdown Styles */
  .dropdown {
    position: relative;
    display: inline-block;
  }

  .dropdown-trigger {
    background: none;
    border: none;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text-primary);
    padding: 0.5rem 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    text-decoration: none;
  }

  .dropdown-trigger:hover {
    color: var(--accent-primary);
  }

  .dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background-color: var(--bg-primary);
    border: 3px solid var(--border-color);
    box-shadow: 4px 4px 0px var(--border-color);
    padding: 0.5rem 0;
    list-style: none;
    z-index: 100;
    min-width: 160px;
    margin: 0;
  }

  .dropdown-menu li {
    margin: 0;
  }

  .dropdown-menu a {
    display: block;
    padding: 0.6rem 1.2rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: background-color var(--transition-fast);
  }

  .dropdown-menu a:hover {
    background-color: var(--accent-primary);
    color: #000000;
  }

  /* Show dropdown menu on hover */
  .dropdown:hover .dropdown-menu,
  .dropdown:focus-within .dropdown-menu {
    display: block;
  }

  .dropdown-trigger .arrow {
    font-size: 0.7rem;
    transition: transform 0.2s ease;
  }

  .dropdown:hover .dropdown-trigger .arrow {
    transform: rotate(180deg);
  }

  /* Hamburger button styles */
  .hamburger-btn {
    display: none;
  }

  /* Responsive styles for header */
  @media (max-width: 767px) {
    .nav-links {
      display: none !important;
    }

    .hamburger-btn {
      display: block;
      background: var(--bg-primary);
      border: 3px solid var(--border-color);
      box-shadow: 2px 2px 0px var(--border-color);
      font-size: 1.5rem;
      padding: 0.3rem 0.7rem;
      cursor: pointer;
      font-weight: bold;
      transition: all 0.15s ease;
      color: var(--text-primary);
      line-height: 1;
    }

    .hamburger-btn:active {
      transform: translate(2px, 2px);
      box-shadow: 0px 0px 0px var(--border-color);
    }
  }

  /* Mobile Drawer & Overlay Styles */
  .mobile-drawer {
    position: fixed;
    top: 0;
    right: -100%;
    width: 85%;
    max-width: 380px;
    height: 100vh;
    background-color: var(--bg-primary);
    border-left: 3px solid var(--border-color);
    box-shadow: -6px 0px 0px var(--border-color);
    z-index: 1000;
    transition: right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    padding: 2rem 1.5rem;
  }

  .mobile-drawer.open {
    right: 0;
  }

  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(9, 9, 11, 0.6);
    z-index: 999;
    display: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .mobile-overlay.open {
    display: block;
    opacity: 1;
  }

  .mobile-drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px dashed var(--border-color);
  }

  .mobile-drawer-header .close-btn {
    background: none;
    border: none;
    font-size: 2.2rem;
    cursor: pointer;
    font-weight: bold;
    color: var(--text-primary);
    padding: 0 0.5rem;
    line-height: 1;
  }

  .mobile-drawer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-drawer-nav > ul > li {
    margin-bottom: 1.5rem;
  }

  .mobile-drawer-nav > ul > li > a {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--text-primary);
    text-decoration: none;
    display: block;
    transition: color 0.2s ease;
  }

  .mobile-drawer-nav > ul > li > a:hover {
    color: var(--accent-primary);
  }

  .mobile-nav-group-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 0.05em;
    margin-bottom: 0.8rem;
    margin-top: 0.5rem;
  }

  .mobile-submenu {
    padding-left: 0.8rem;
    border-left: 2px solid var(--border-color);
    margin-bottom: 1rem;
  }

  .mobile-submenu li {
    margin-bottom: 0.6rem;
  }

  .mobile-submenu a {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-secondary);
    text-decoration: none;
    display: block;
  }

  .mobile-submenu a:hover {
    color: var(--accent-primary);
  }

  .mobile-submenu a.view-all-services {
    color: var(--accent-primary);
    font-size: 0.9rem;
    margin-top: 0.8rem;
  }

  .mobile-cta-li {
    margin-top: 3rem;
  }

  .mobile-cta-li .btn {
    display: block;
    width: 100%;
    text-align: center;
    border-width: 3px;
    font-size: 1.1rem;
    padding: 0.8rem;
  }
</style>
